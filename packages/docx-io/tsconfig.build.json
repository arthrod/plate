{
"compilerOptions": {
	"target": "ES2020",
	"module": "ESNext",
	"moduleResolution": "bundler",
	"strict": false,
	"isolatedModules": true,
	"skipLibCheck": true,
	"esModuleInterop": true,
	"allowSyntheticDefaultImports": true,
	"resolveJsonModule": true,
	"sourceMap": true,
	"types": [
		"node",
		"bun",
		"json"
	]
},
"include": [
	"index.ts",
	"src/**/*.ts"
],
"exclude": [
	"**/*.spec.ts",
	"**/*.test.ts",
	"dist",
	"node_modules"
]
}
